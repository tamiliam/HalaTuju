# Microsoft Office lock files (created while a doc is open)
~$*

# Git worktrees for parallel-agent isolation (never committed)
.worktrees/

# Data dumps / table backups must NEVER be committed — a legacy student_profiles
# backup with real PII was purged from history on 2026-07-03 (git filter-repo).
**/docs/backups/
*_backup_*.json
